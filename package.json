{
  "name": "shotcompare",
  "productName": "ShotCompare",
  "version": "0.1.0",
  "description": "Local-first desktop tool for finding and comparing visually similar video shots.",
  "author": "ShotCompare",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/serve.mjs",
    "dev:vite": "vite --host 127.0.0.1",
    "electron:dev": "node scripts/electron-dev.mjs",
    "build": "vite build",
    "package:electron": "pnpm build && electron-builder --dir",
    "dist:electron": "pnpm build && electron-builder",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test tests/*.test.mjs",
    "check": "node --check scripts/serve.mjs && node --check scripts/electron-dev.mjs && node --check src/app.js && node --check electron/main.cjs && node --check electron/preload.cjs && node --check electron/clip-drag.cjs"
  },
  "dependencies": {
    "blockhash": "0.2.0",
    "ffmpeg-static": "^5.3.0",
    "jpeg-js": "^0.4.4",
    "png-js": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "vite": "^7.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  },
  "build": {
    "appId": "com.shotcompare.app",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
